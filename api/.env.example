NODE_ENV=production
PORT=3000
# Docker Compose 中主机名必须为 postgres；部署时与 infra/.env 的 POSTGRES_PASSWORD 保持一致
DATABASE_URL="postgresql://erp:replace-with-a-long-random-password@postgres:5432/fabric_erp?schema=public"
JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
JWT_REFRESH_SECRET=replace-with-a-different-at-least-32-random-characters
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
# 仅填写正式 HTTPS 前端来源；多个来源时须确认应用的 CORS 配置支持其格式
CORS_ORIGIN=https://erp.example.com
# 每个 IP 在对应限流窗口内允许的最大请求数，按业务容量调整
AUTH_LOGIN_RATE_LIMIT_MAX=10
AUTH_REFRESH_RATE_LIMIT_MAX=30
UPLOAD_RATE_LIMIT_MAX=30
